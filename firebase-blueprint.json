{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and gamification data",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string", "description": "User's public name" },
        "email": { "type": "string", "format": "email", "description": "User's email" },
        "photoURL": { "type": "string", "format": "uri", "description": "Profile picture URL" },
        "points": { "type": "number", "description": "Total points earned" },
        "level": { "type": "number", "description": "Current user level" },
        "badges": { "type": "array", "items": { "type": "string" }, "description": "List of earned badges" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "email", "points", "level"]
    },
    "Report": {
      "title": "Waste Report",
      "description": "A report of a waste hotspot or classified item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "reporterId": { "type": "string", "description": "UID of the user who reported" },
        "reporterName": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "category": { "type": "string", "enum": ["plastic", "organic", "metal", "paper", "e-waste", "other"] },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "verified", "cleaned"] },
        "pointsAwarded": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["reporterId", "imageUrl", "location", "category", "status", "timestamp"]
    },
    "CollectionPoint": {
      "title": "Collection Point",
      "description": "A fixed location for waste disposal",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "typesAccepted": { "type": "array", "items": { "type": "string" } },
        "address": { "type": "string" }
      },
      "required": ["name", "location", "typesAccepted"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/reports/{reportId}": {
      "schema": "Report",
      "description": "Waste reports"
    },
    "/collectionPoints/{pointId}": {
      "schema": "CollectionPoint",
      "description": "Fixed collection points"
    }
  }
}
